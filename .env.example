# ── Database ───────────────────────────────────────────────
POSTGRES_USER=vault_user
POSTGRES_PASSWORD=vault_pass_change_me
POSTGRES_DB=password_manager
DATABASE_URL=postgresql+asyncpg://vault_user:vault_pass_change_me@db:5432/password_manager

# ── Security (generate strong random values for production) ──
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_with_secrets_token_hex_32
# python -c "import secrets; print(secrets.token_urlsafe(32))"
MASTER_ENCRYPTION_KEY=change_me_generate_with_secrets_token_urlsafe_32

# ── Token lifetimes ───────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── File storage ──────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50

# ── App ───────────────────────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:5173
